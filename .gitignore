# ---- Dependencies ----
node_modules/
.pnp
.pnp.js
frontend/node_modules/
backend/.venv/
backend/venv/
**/__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ---- Build / output ----
.next/
out/
build/
dist/
frontend/.next/
frontend/out/
*.tsbuildinfo
next-env.d.ts

# ---- Environment / secrets ----
.env
.env*.local
.env.local
*.pem

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ---- Editor / OS ----
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# ---- Agent / assistant artifacts (never publish) ----
.claude/
CLAUDE.md
AGENTS.md
.cursor/
.aider*

# ---- Docs / markdown (kept out of the repo by request) ----
# Everything markdown stays out EXCEPT the top-level project README.
*.md
!.keep
!/README.md

# ---- Source problem statement & private material ----
*.pdf
problem_explanation_*.pdf

# ---- Data / model artifacts that are large or regenerable ----
# (regenerated by `python -m app.ml.train`; metrics.json is kept as a record)
backend/data/raw/
backend/models/*.joblib
backend/models/portfolio.json
# 3D source asset lives here but is served (and committed) from frontend/public
backend/models/*.glb
*.onnx.bak
